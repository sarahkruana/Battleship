import GameModel

class TestGameModel:
    def test_place_ship_valid():
        model = GameModel()
        result = model.place_ship(player1, valid_coordinates)
        assert result == True

    def test_place_ship_invalid():
        model = GameModel()
        result = model.place_ship(player1, invalid_coordinates)
        assert result == False

    def test_hit_detection():
        model = GameModel()
        model.place_ship(player2, ship_location)
        result = model.confirm_target(player1, ship_location)
        assert result == "hit"

    def test_winner_detection():
        model = GameModel()
        sink_all_ships(player2)
        winner = model.check_winner()
        assert winner == player1
